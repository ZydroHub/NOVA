# NOVA / Pocket AI environment configuration
# Copy this file to .env and fill in your own values.

# Server
PORT=8000

# Paths (relative to project root)
CONVERSATIONS_FILE=conversations.json
TOOLS_PATH=tools.json
JOBS_FILE=task_jobs.json
LOCAL_DIR=./models

# Chat LLM (Qwen)
CHAT_REPO_ID=Qwen/Qwen3-0.6B-GGUF
CHAT_FILENAME=Qwen3-0.6B-Q8_0.gguf

# Tool LLM (Function Gemma)
TOOL_REPO_ID=nlouis/functiongemma-pocket-q4_k_m
TOOL_FILENAME=functiongemma-pocket-q4_k_m.gguf

# Telegram bot
# The bot learns the chat id when a user sends /Nacka, /stockholm, or /test.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_SUBSCRIPTIONS_FILE=telegram_subscriptions.json
TELEGRAM_POLL_INTERVAL_SECONDS=60
TELEGRAM_UPDATE_POLL_TIMEOUT_SECONDS=30
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
TELEGRAM_MAX_RETRIES=3

# Logging (optional)
# LOG_LEVEL=INFO
# LOG_FILE=
